# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Supabase (URL + anon/publishable key only — never put a service-role
# key here or anywhere the backend commits to git)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional. Defaults to 3001 if not set.
PORT=

# Comma-separated list of frontend origins allowed to call this API
# (CORS). Defaults to http://localhost:5173 (the local Vite dev server)
# if not set. Set this to your deployed frontend URL(s) in production —
# without it, only localhost can call the API.
# Example: ALLOWED_ORIGINS=https://claritycoach.app,https://www.claritycoach.app
ALLOWED_ORIGINS=

# Used to build the link included in team-invite emails/responses
# (e.g. https://claritycoach.app/accept-invite?token=...). Defaults to
# http://localhost:5173 if not set.
FRONTEND_URL=
